# ============================================
# Keep these files (exceptions)
# ============================================
# Do not ignore small example images for documentation
!docs/**/*.png
!docs/**/*.jpg
!assets/**/*.png
!assets/**/*.jpg

# Do not ignore configuration templates
!configs/**/*.py
!configs_ltdnet/**/*.py

# Do not ignore requirements
!requirements/**/*.txt

# Do not ignore documentation
!*.md
!*.rst
!*.txt
